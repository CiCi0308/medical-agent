# ===== LLM / Alibaba Cloud Bailian (OpenAI-compatible) =====
ARK_API_KEY=your_api_key
BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL=qwen-plus
GRADE_MODEL=qwen-turbo
FAST_MODEL=qwen-turbo
OCR_MODEL=qwen-vl-plus

# ===== Local Embeddings =====
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
DENSE_EMBEDDING_DIM=1024

# ===== Rerank (optional) =====
# RERANK_MODEL=jina-reranker-v3
# RERANK_BINDING_HOST=https://api.jina.ai/v1/rerank
# RERANK_API_KEY=your_rerank_api_key

# ===== Milvus =====
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION=embeddings_collection
MILVUS_TIMEOUT_SECONDS=3

# ===== Database / Cache =====
DATABASE_URL=sqlite:///./data/dev.db
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_KEY_PREFIX=medical-agent

# ===== Auth =====
JWT_SECRET_KEY=replace-with-a-strong-random-secret
ADMIN_INVITE_CODE=medical-agent-admin-2026
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
PASSWORD_PBKDF2_ROUNDS=310000

# ===== BM25 Sparse State =====
# BM25_STATE_PATH=./data/bm25_state.json

# ===== Medical Knowledge Graph =====
# Point this to the DiseaseKG JSON exported from RAGQnASystem.
MEDICAL_KG_DATA_PATH=./data/medical_new_2.json
# NEO4J_BOLT_URL=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your_neo4j_password
# NEO4J_DATABASE=neo4j

# ===== Optional tools =====
# AMAP_WEATHER_API=https://restapi.amap.com/v3/weather/weatherInfo
# AMAP_API_KEY=your_amap_api_key
